#!/usr/bin/env sh

export JAVA_HOME=${JAVA_HOME:-$(/usr/libexec/java_home 2>/dev/null)}

DIR="$(cd "$(dirname "$0")" && pwd)"
WRAPPER_JAR="$DIR/gradle/wrapper/gradle-wrapper.jar"
WRAPPER_SHARED_JAR="$DIR/gradle/wrapper/gradle-wrapper-shared.jar"

if [ ! -f "$WRAPPER_JAR" ] || [ ! -f "$WRAPPER_SHARED_JAR" ]; then
  echo "Gradle wrapper jars missing at $WRAPPER_JAR and $WRAPPER_SHARED_JAR" >&2
  exit 1
fi

exec java -Xmx64m -classpath "$WRAPPER_JAR:$WRAPPER_SHARED_JAR" org.gradle.wrapper.GradleWrapperMain "$@"
